<?xml version="1.0" encoding="UTF-8"?>
<configuration>
  <system.webServer>

    <!-- Serve the React SPA index for unknown routes -->
    <defaultDocument>
      <files>
        <clear />
        <add value="router.php" />
      </files>
    </defaultDocument>

    <rewrite>
      <rules>
        <!-- Block direct access to sensitive directories -->
        <rule name="Block includes" stopProcessing="true">
          <match url="^includes/" />
          <action type="CustomResponse" statusCode="403" statusReason="Forbidden" statusDescription="Access Denied" />
        </rule>
        <rule name="Block storage db" stopProcessing="true">
          <match url="^storage/database\.sqlite" />
          <action type="CustomResponse" statusCode="403" statusReason="Forbidden" statusDescription="Access Denied" />
        </rule>

        <!-- Let real files and directories through -->
        <rule name="Static files" stopProcessing="true">
          <match url=".*" />
          <conditions>
            <add input="{REQUEST_FILENAME}" matchType="IsFile" />
          </conditions>
          <action type="None" />
        </rule>

        <!-- Route everything else through router.php -->
        <rule name="PHP Router" stopProcessing="true">
          <match url="(.*)" />
          <action type="Rewrite" url="router.php" appendQueryString="true" />
        </rule>
      </rules>
    </rewrite>

    <!-- Security headers -->
    <httpProtocol>
      <customHeaders>
        <add name="X-Frame-Options" value="SAMEORIGIN" />
        <add name="X-Content-Type-Options" value="nosniff" />
        <add name="X-XSS-Protection" value="1; mode=block" />
      </customHeaders>
    </httpProtocol>

    <!-- Prevent directory listing -->
    <directoryBrowse enabled="false" />

  </system.webServer>

  <!-- PHP settings -->
  <system.web>
    <compilation debug="false" />
  </system.web>
</configuration>
